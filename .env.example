# === OpenClaw Claude Proxy v4.0 ===
# Persistent Session Edition

# Server port
PORT=3456

# API key for authenticating incoming requests (leave empty for no auth)
API_KEY=

# Max concurrent requests (recommended: 2 for Claude Max subscription)
MAX_CONCURRENT=2

# Request timeout in milliseconds (5 minutes)
REQUEST_TIMEOUT=300000

# Auto-retry failed requests (0 = no retry)
MAX_RETRIES=1

# Plugin directory (drop .js files here for pre/post processing)
PLUGINS_DIR=./plugins
