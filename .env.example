# === OpenClaw Claude Proxy v3.0 ===

# Server port
PORT=3456

# API key for authenticating incoming requests (set your own secret)
API_KEY=sk-openclaw-proxy-change-me

# Claude Code CLI path (for legacy /v1/chat/completions endpoint)
CLAUDE_CLI_PATH=claude

# Max concurrent requests (recommended: 2 for Claude Max subscription)
MAX_CONCURRENT=2

# Request timeout in milliseconds (5 minutes)
REQUEST_TIMEOUT=300000

# Auto-retry failed CLI calls (0 = no retry)
MAX_RETRIES=1

# Plugin directory (drop .js files here for pre/post processing)
PLUGINS_DIR=./plugins
